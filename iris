#!/bin/bash

# ─────────────────────────────────────────────
#  iris — unified CLI dispatcher
#  https://github.com/rhythwitty/bashrepo
# ─────────────────────────────────────────────

IRIS_VERSION="1.0.0"
IRIS_LIB_DIR="/usr/local/lib/iris"
IRIS_UPDATE_URL="https://github.com/rhythwitty/bashrepo/raw/main/install.sh"
IRIS_RAW_URL="https://github.com/rhythwitty/bashrepo/raw/main/iris"

show_help() {
    if command -v tput &>/dev/null; then
        bold=$(tput bold); reset=$(tput sgr0)
    else
        bold=""; reset=""
    fi

    echo ""
    echo "${bold}iris v${IRIS_VERSION}${reset} — utility scripts"
    echo ""
    echo "${bold}USAGE${reset}"
    echo "    iris <command> [options]"
    echo ""
    echo "${bold}COMMANDS${reset}"
    if [[ -d "$IRIS_LIB_DIR" ]]; then
        for script in "$IRIS_LIB_DIR"/*.sh; do
            [[ -f "$script" ]] || continue
            cmd=$(basename "$script" .sh)
            desc=$(grep -m1 '^# IRIS_DESC:' "$script" | sed 's/^# IRIS_DESC: *//')
            printf "    %-20s %s\n" "$cmd" "${desc:----}"
        done
    else
        echo "    (no commands installed — run install.sh)"
    fi
    echo ""
    echo "${bold}OTHER${reset}"
    echo "    iris --update          Update iris and all scripts"
    echo "    iris --upgrade         Alias for --update"
    echo "    iris --version         Show version"
    echo "    iris --help            Show this help"
    echo ""
}

case "$1" in
    ""|--help|-h)
        show_help
        ;;
    --version|-v)
        echo "iris v${IRIS_VERSION}"
        ;;
    --update|--upgrade)
        echo "Checking for updates..."
        REMOTE_VERSION=$(curl -sL "$IRIS_RAW_URL" | grep -m1 '^IRIS_VERSION=' | cut -d'"' -f2)
        
        if [[ -z "$REMOTE_VERSION" ]]; then
            echo "⚠️  Could not check remote version. Proceeding with update..."
        elif [[ "$IRIS_VERSION" == "$REMOTE_VERSION" ]]; then
            echo "✅  iris is already up to date (v${IRIS_VERSION})."
            exit 0
        else
            echo "🔄  New version available: v${IRIS_VERSION} → v${REMOTE_VERSION}"
        fi

        echo "Updating iris and scripts..."
        curl -sL "$IRIS_UPDATE_URL" | bash
        ;;
    *)
        SCRIPT="$IRIS_LIB_DIR/$1.sh"
        if [[ -x "$SCRIPT" ]]; then
            required_platform=$(grep -m1 '^# IRIS_PLATFORM:' "$SCRIPT" | sed 's/^# IRIS_PLATFORM: *//')
            if [[ -n "$required_platform" ]]; then
                current_platform=$(uname -s | tr '[:upper:]' '[:lower:]' | sed 's/darwin/macos/')
                if [[ "$current_platform" != "$required_platform" ]]; then
                    echo "❌  '$1' is only supported on $required_platform."
                    exit 1
                fi
            fi
            shift
            exec "$SCRIPT" "$@"
        else
            echo "❌  Unknown command: $1"
            echo "    Run 'iris' to see available commands."
            exit 1
        fi
        ;;
esac
